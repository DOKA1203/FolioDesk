<Window x:Class="FolioDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FolioDesk"
        Title="FolioDesk"
        Width="360" Height="200"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="20" Background="#0F1222" Padding="16">
        <Grid>

            <!-- 상단 타이틀바 -->
            <Grid VerticalAlignment="Top" Height="40"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock Text="FolioDesk" Foreground="White" FontWeight="Bold" Padding="5 0 0 0 " />
                        <TextBlock Text="{DynamicResource AppSubtitle}" Foreground="#888" FontSize="10" Padding="5 0 0 0 "/>
                    </StackPanel>
                </StackPanel>

                <!-- 오른쪽 버튼 -->
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button Content="{DynamicResource LangToggle}" Style="{StaticResource TitleButton}" Click="ToggleLang_Click"/>
                    <Button Style="{StaticResource TitleButton}" Click="CheckUpdate_Click" ToolTip="GitHub Releases">
                        <Viewbox Width="13" Height="13">
                            <Path Fill="White"
                                  Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                        </Viewbox>
                    </Button>
                    <Button Content="✕" Style="{StaticResource TitleButton}" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- 버전 표시 -->
            <TextBlock Text="{x:Static local:App.Version}"
                       VerticalAlignment="Bottom" HorizontalAlignment="Right"
                       Foreground="#999" FontSize="12" Margin="0,0,4,4"/>

            <!-- 중앙 컨텐츠 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- 버튼 -->
                <Button Content="{DynamicResource NewFolder}"
                        Width="180" Height="45"
                        Background="#7C6CF2"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CreateFolder">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="12"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </Grid>
    </Border>
</Window>
