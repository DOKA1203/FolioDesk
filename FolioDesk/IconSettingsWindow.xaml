<Window x:Class="FolioDesk.IconSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FolioDesk" Width="260" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False">

    <Border CornerRadius="16" Background="#F2141624" Padding="16">
        <StackPanel>

            <!-- 타이틀바 -->
            <Grid Height="36" Margin="0,0,0,12"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="{DynamicResource IconColorTitle}" Foreground="White"
                           FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right"
                        Style="{StaticResource TitleButton}"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- 미리보기 -->
            <Border x:Name="PreviewBorder"
                    Width="64" Height="64" CornerRadius="12"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,14"/>

            <!-- SV 피커 -->
            <Grid x:Name="SvGrid" Height="148" Margin="0,0,0,10"
                  Cursor="Cross"
                  MouseDown="SvGrid_MouseDown"
                  MouseMove="SvGrid_MouseMove"
                  MouseUp="SvGrid_MouseUp">
                <Border CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <Rectangle x:Name="SvHueRect"/>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#FF000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Border>
                <Canvas x:Name="SvCanvas">
                    <Ellipse x:Name="SvThumb" Width="14" Height="14"
                             Stroke="White" StrokeThickness="2"
                             Fill="Transparent"
                             Canvas.Left="-7" Canvas.Top="-7"
                             IsHitTestVisible="False">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="0"
                                              Opacity="0.8" Color="Black"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>
            </Grid>

            <!-- Hue 슬라이더 -->
            <Grid x:Name="HueGrid" Height="22" Margin="0,0,0,12"
                  Cursor="Hand"
                  MouseDown="HueGrid_MouseDown"
                  MouseMove="HueGrid_MouseMove"
                  MouseUp="HueGrid_MouseUp">
                <Border CornerRadius="6" Height="16" VerticalAlignment="Center"
                        ClipToBounds="True">
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF0000" Offset="0"/>
                                <GradientStop Color="#FFFF00" Offset="0.1667"/>
                                <GradientStop Color="#00FF00" Offset="0.3333"/>
                                <GradientStop Color="#00FFFF" Offset="0.5"/>
                                <GradientStop Color="#0000FF" Offset="0.6667"/>
                                <GradientStop Color="#FF00FF" Offset="0.8333"/>
                                <GradientStop Color="#FF0000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Border>
                <Canvas x:Name="HueCanvas">
                    <Rectangle x:Name="HueThumb" Width="6" Height="22"
                               RadiusX="3" RadiusY="3" Fill="White"
                               Canvas.Left="-3" Canvas.Top="0"
                               IsHitTestVisible="False">
                        <Rectangle.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                              Opacity="0.7" Color="Black"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </Canvas>
            </Grid>

            <!-- Hex 입력 -->
            <DockPanel Margin="0,0,0,14" Height="32">
                <TextBlock DockPanel.Dock="Left" Text="#"
                           Foreground="#888888" FontFamily="Consolas" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Border Background="#1E1E2E" CornerRadius="7">
                    <TextBox x:Name="HexInput"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" FontFamily="Consolas" FontSize="14"
                             Padding="8,0" MaxLength="6" CharacterCasing="Upper"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="HexInput_PreviewTextInput"
                             TextChanged="HexInput_TextChanged"/>
                </Border>
            </DockPanel>

            <!-- 투명도 슬라이더 -->
            <StackPanel>
                <DockPanel Margin="0,0,0,4">
                    <TextBlock Text="{DynamicResource Opacity}" Foreground="#AAAAAA"
                               FontSize="12" VerticalAlignment="Center"
                               DockPanel.Dock="Left"/>
                    <TextBlock x:Name="OpacityLabel" Foreground="White"
                               FontSize="12" VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               DockPanel.Dock="Right"/>
                </DockPanel>
                <Slider x:Name="OpacitySlider"
                        Minimum="10" Maximum="100" Value="100"
                        TickFrequency="10" IsSnapToTickEnabled="False"
                        ValueChanged="OpacitySlider_ValueChanged"/>
            </StackPanel>

            <!-- 적용 버튼 -->
            <Button x:Name="ApplyButton"
                    Content="{DynamicResource Apply}" Width="160" Height="38"
                    Margin="0,20,0,0" HorizontalAlignment="Center"
                    Click="Apply_Click" Foreground="White"
                    FontSize="14" FontWeight="Bold" BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#7C6CF2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" CornerRadius="10"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#9080FF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#6050D0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</Window>